{
  "name": "weather-alerts-card",
  "version": "2.10.0",
  "description": "A custom Home Assistant Lovelace card for displaying weather alerts",
  "main": "dist/weather-alerts-card.js",
  "module": "dist/weather-alerts-card.js",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "screenshot": "node scripts/screenshot.js",
    "screenshot:update": "npm run build && npm run screenshot",
    "screenshot:hero": "npm run build && npm run screenshot && bash scripts/encode-adaptive-svgs.sh"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "nws",
    "bom",
    "meteoalarm",
    "weather",
    "alerts"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@mdi/js": "^7.4.47",
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/dompurify": "^3.0.5",
    "@vitest/browser": "^4.1.2",
    "conventional-changelog-cli": "^5.0.0",
    "conventional-recommended-bump": "^11.2.0",
    "git-cliff": "^2.12.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.59.1",
    "rollup": "^4.60.1",
    "rollup-plugin-typescript2": "^0.37.0",
    "semver": "^7.7.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "custom-card-helpers": "^1.9.0",
    "dompurify": "^3.3.3",
    "lit": "^3.3.2"
  }
}
